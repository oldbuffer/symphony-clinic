{% extends 'base.html.twig' %}

{% block title %}Список пациентов{% endblock %}

{% block body %}
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Пациенты</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('patient_new') }}" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">+ Новый пациент</a>
        {% endif %}
    </div>

    {% if patients is empty %}
        <p class="text-gray-500">Пока нет пациентов.</p>
    {% else %}
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <ul class="divide-y divide-gray-200">
            {% for patient in patients %}
                <li class="px-6 py-4 flex justify-between items-center">
                    <div>
                        <a href="{{ path('patient_show', {id: patient.id}) }}" class="text-lg font-medium text-indigo-600 hover:text-indigo-900">{{ patient.name }}</a>
                        <p class="text-sm text-gray-500">{{ patient.email }}</p>
                    </div>
                    <div class="text-sm text-gray-400">
                        {% if patient.phone %}{{ patient.phone }}{% endif %}
                        {% if patient.birthDate %} · {{ patient.birthDate|date('d.m.Y') }}{% endif %}
                    </div>
                </li>
            {% endfor %}
            </ul>
        </div>
    {% endif %}
{% endblock %}